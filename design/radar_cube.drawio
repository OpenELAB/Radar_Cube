        <mxCell id="7CyqZpYL4BO0aw3nbGov-220" value="&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;text-align: center;&quot;&gt;&lt;b&gt;4. 配置深度睡眠及其唤醒，然后进入睡眠&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" vertex="1" parent="1">
